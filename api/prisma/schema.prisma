generator client {
  provider = "prisma-client-js"
  output   = "../generated/prisma"
}

datasource db {
  provider = "postgresql"
}

model User {
  id       String  @id @default(uuid())
  nickname String
  username String  @unique
  password String?
  email    String  @unique
  googleId String? @unique
}

model Session {
  id        String   @id
  sid       String   @unique
  data      String
  expiresAt DateTime
}

model Chatroom {
  id       Int       @id @default(autoincrement())
  name     String    @unique
  messages Message[]
}

model Message {
  id         String   @id @default(uuid())
  chatroom   Chatroom @relation(fields: [chatroomId], references: [id])
  chatroomId Int
}
