generator client {
  provider = "prisma-client-js"
  output   = "../generated/prisma"
}

datasource db {
  provider = "postgresql"
}

enum UserStatus {
  ONLINE
  IDLE
}

model User {
  id               String          @id @default(uuid())
  nickname         String
  username         String          @unique
  password         String?
  email            String          @unique
  googleId         String?         @unique
  bio              String          @default("hi im new here")
  status           UserStatus      @default(IDLE)
  bannerColour     String          @default("#5865F2")
  reactions        Reaction[]
  sentRequests     FriendRequest[] @relation("senderId")
  receivedRequests FriendRequest[] @relation("receiverId")
}

enum FriendRequestStatus {
  ACCEPTED
  PENDING
  REJECTED
}

model FriendRequest {
  id            String              @id @default(uuid())
  requestStatus FriendRequestStatus @default(PENDING)
  sender        User                @relation("senderId", fields: [senderId], references: [id])
  senderId      String
  receiver      User                @relation("receiverId", fields: [receiverId], references: [id])
  receiverId    String
}

model Session {
  id        String   @id
  sid       String   @unique
  data      String
  expiresAt DateTime
}

model Chatroom {
  id       Int       @id @default(autoincrement())
  name     String    @unique
  messages Message[]
}

model Message {
  id          String     @id @default(uuid())
  chatroom    Chatroom   @relation(fields: [chatroomId], references: [id])
  chatroomId  Int
  replyId     Int?
  reaction    Reaction[]
  createdAt   DateTime   @default(now())
  messageBody String
}

enum ReactionType {
  LOVE
  LAUGH
  WOW
  CRY
  OK
}

model Reaction {
  id        Int          @id @default(autoincrement())
  sender    User         @relation(fields: [senderId], references: [id])
  senderId  String
  type      ReactionType
  message   Message      @relation(fields: [messageId], references: [id])
  messageId String

  @@unique([senderId, messageId, type])
}
